# PRAHARI — copy to .env and fill what you have. Everything is optional:
# each missing key degrades that feed gracefully (never breaks the console).

# aisstream.io — free; register at https://aisstream.io (do this day 0)
AISSTREAM_API_KEY=

# EIA open data — free; https://www.eia.gov/opendata/
EIA_API_KEY=

# Anthropic — for LLM brief narration + signal adjudication
ANTHROPIC_API_KEY=

# 1 = poll GDELT (no key needed)
GDELT_ENABLED=1

# 1 = record all signals to backend/data/replay/*.jsonl for the replay harness
RECORD_SIGNALS=1
